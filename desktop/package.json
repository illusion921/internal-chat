{
  "name": "internal-chat-desktop",
  "version": "1.0.0",
  "description": "内网聊天系统桌面客户端",
  "main": "dist/main.js",
  "author": {
    "name": "Internal Chat Team",
    "email": "team@internal-chat.local"
  },
  "homepage": "https://github.com/illusion921/internal-chat",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "package": "electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "antd": "^5.12.0",
    "zustand": "^4.4.7",
    "axios": "^1.6.2",
    "socket.io-client": "^4.7.2",
    "@ant-design/icons": "^5.2.6"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.2",
    "vite": "^5.0.7"
  },
  "build": {
    "appId": "com.internal-chat.desktop",
    "productName": "内网聊天",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        { "target": "zip", "arch": ["x64"] }
      ]
    },
    "linux": {
      "target": [
        { "target": "deb", "arch": ["x64", "arm64"] },
        { "target": "AppImage", "arch": ["x64", "arm64"] }
      ],
      "category": "Network",
      "maintainer": "Internal Chat Team <team@internal-chat.local>"
    }
  }
}
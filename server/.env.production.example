# 生产环境配置示例

# 服务器端口
PORT=3001

# 数据库连接 (SQLite)
DATABASE_URL=file:/app/data/chat.db

# Redis 连接
REDIS_URL=redis://redis:6379

# JWT 配置
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 文件上传配置
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=524288000

# 客户端地址 (CORS)
CLIENT_URL=http://localhost:5173
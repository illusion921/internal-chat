// Prisma Schema for Internal Chat (PostgreSQL)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  nickname     String
  avatar       String?
  signature    String?
  status       String   @default("offline") // online, offline
  lastSeenAt   DateTime? @map("last_seen_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // 关系
  sentFriendRequests    Friendship[] @relation("UserFriends")
  receivedFriendRequests Friendship[] @relation("ReceivedFriends")
  ownedGroups           Group[]      @relation("GroupOwner")
  groupMemberships      GroupMember[]
  sentMessages          Message[]    @relation("MessageSender")
  uploadedFiles         File[]       @relation("FileUploader")
  friendGroups          FriendGroup[]

  @@map("users")
}

// 好友分组表
model FriendGroup {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  // 关系
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  friendships Friendship[]

  @@unique([userId, name]) // 同一用户不能创建同名分组
  @@index([userId])
  @@map("friend_groups")
}

// 好友关系表
model Friendship {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  friendId   String   @map("friend_id")
  status     String   @default("pending") // pending, accepted, rejected
  remark     String?  @db.Text
  groupId    String?  @map("group_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // 关系
  user       User        @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend     User        @relation("ReceivedFriends", fields: [friendId], references: [id], onDelete: Cascade)
  group      FriendGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([userId, friendId])
  @@map("friendships")
}

// 群组表
model Group {
  id           String   @id @default(uuid())
  name         String
  avatar       String?
  announcement String?  @db.Text
  ownerId      String   @map("owner_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // 关系
  owner        User          @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      GroupMember[]

  @@map("groups")
}

// 群成员表
model GroupMember {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  role      String   @default("member") // owner, admin, member
  nickname  String?
  joinedAt  DateTime @default(now()) @map("joined_at")

  // 关系
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

// 消息表
model Message {
  id               String   @id @default(uuid())
  conversationId   String   @map("conversation_id")
  conversationType String   @map("conversation_type") // private, group
  senderId         String   @map("sender_id")
  content          String?  @db.Text
  msgType          String   @default("text") @map("msg_type") // text, image, file
  fileId           String?  @map("file_id")
  mentionIds       String?  @map("mention_ids") // JSON 数组，@的用户ID列表
  recalledAt       DateTime? @map("recalled_at") // 撤回时间
  createdAt        DateTime @default(now()) @map("created_at")

  // 关系
  sender    User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  file      File?    @relation(fields: [fileId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([createdAt])
  @@index([content]) // 用于消息搜索
  @@map("messages")
}

// 文件表
model File {
  id         String   @id @default(uuid())
  filename   String
  filepath   String
  filesize   Int
  mimeType   String?  @map("mime_type")
  uploaderId String   @map("uploader_id")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  // 关系
  uploader   User      @relation("FileUploader", fields: [uploaderId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@map("files")
}